{
  "name": "couch-games",
  "version": "2.2.0",
  "description": "Browser-based multiplayer stacker with phone controllers",
  "main": "server/index.js",
  "scripts": {
    "start": "node scripts/generate-airconsole-html.js && node server/index.js",
    "dev": "node scripts/generate-airconsole-html.js && node --watch server/index.js",
    "test": "node --test tests/*.test.js",
    "test:visual": "npx playwright test --project=display --project=controller",
    "test:visual:update": "npx playwright test --project=display --project=controller --update-snapshots",
    "test:e2e": "npx playwright test --project=e2e",
    "test:e2e:airconsole": "AC_MOCK=1 npx playwright test --project=e2e-airconsole",
    "ad:pieces": "node ad/scripts/generate-piece-assets.js",
    "ad:display": "node ad/scripts/capture-display-clip.js",
    "ad:controller": "node ad/scripts/capture-controller-clip.js",
    "ad:all": "npm run ad:pieces && npm run ad:display && npm run ad:controller"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
