{
  "name": "tetris-party",
  "version": "1.2.0",
  "description": "Browser-based multiplayer Tetris with phone controllers",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "node --test tests/*.test.js",
    "test:visual": "npx playwright test",
    "test:visual:update": "npx playwright test --update-snapshots",
    "ad:pieces": "node ad/scripts/generate-piece-assets.js",
    "ad:display": "node ad/scripts/capture-display-clip.js",
    "ad:controller": "node ad/scripts/capture-controller-clip.js",
    "ad:all": "npm run ad:pieces && npm run ad:display && npm run ad:controller"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
